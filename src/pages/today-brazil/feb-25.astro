    <!-- Title -->
    <h1 class="font-display text-3xl sm:text-4xl font-bold text-brazil-blue leading-tight mb-6">
      <span data-lang-content="en">Brazil's Diaspora and the Remittance Lifeline</span>
      <span data-lang-content="zh">巴西海外侨民与汇款生命线</span>
      <span data-lang-content="pt">A Diáspora Brasileira e a Linha de Vida das Remessas</span>
    </h1>

    <!-- Hero image -->
    <img
      src="https://images.pexels.com/photos/3943716/pexels-photo-3943716.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop"
