---
import Layout from '../../layouts/Layout.astro';
import { fetchAllArticles } from '../../lib/supabase';

export async function getStaticPaths() {
  const articles = await fetchAllArticles();
  const slugMap: Record<string, { title_en: string; slug: string }> = {};
  for (const a of articles) {
    slugMap[a.slug] = { title_en: a.title_en, slug: a.slug };
  }
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article, slugMap },
  }));
}

const { article, slugMap } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00Z');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const tagColorMap: Record<string, string> = {
  Remittance: 'bg-green-100 text-brazil-green',
  Technology: 'bg-blue-100 text-brazil-blue',
  Culture: 'bg-yellow-100 text-yellow-700',
  'Exchange Rates': 'bg-orange-100 text-orange-700',
  Guide: 'bg-green-100 text-brazil-green',
  Market: 'bg-gray-100 text-gray-700',
  Economy: 'bg-teal-100 text-teal-700',
  Finance: 'bg-red-100 text-red-700',
  Tips: 'bg-cyan-100 text-cyan-700',
  Regulation: 'bg-blue-100 text-blue-700',
  Diaspora: 'bg-orange-100 text-orange-700',
};

const tagClass = tagColorMap[article.tag] ?? 'bg-gray-100 text-gray-700';

const prevArticle = article.prev_slug ? slugMap[article.prev_slug] : null;
const nextArticle = article.next_slug ? slugMap[article.next_slug] : null;
---

<Layout
  title={article.title_en}
  description={article.excerpt_en}
  keywords={`Brazil remittance, ${article.tag}, ${article.title_en}`}
  image={article.image_url}
  type="article"
  publishedDate={article.published_date}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a href="/today-brazil" class="inline-flex items-center gap-2 text-brazil-green text-sm font-medium hover:underline mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span data-lang-content="en">Back to Today's Brazil</span>
      <span data-lang-content="zh">返回今日巴西</span>
      <span data-lang-content="pt">Voltar para Brasil Hoje</span>
    </a>

    <div class="flex items-center gap-3 mb-4">
      {article.tag && (
        <span class={`px-3 py-1 text-xs font-semibold rounded-full ${tagClass}`}>{article.tag}</span>
      )}
      <time class="text-sm text-gray-400">{formatDate(article.published_date)}</time>
    </div>

    <h1 class="font-display text-3xl sm:text-4xl font-bold text-brazil-blue leading-tight mb-6">
      <span data-lang-content="en">{article.title_en}</span>
      <span data-lang-content="zh">{article.title_zh}</span>
      <span data-lang-content="pt">{article.title_pt}</span>
    </h1>

    {article.image_url && (
      <img
        src={article.image_url}
        alt={article.title_en}
        class="w-full rounded-2xl mb-8 object-cover h-64"
      />
    )}

    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed space-y-5">
      <div data-lang-content="en" set:html={article.body_en} />
      <div data-lang-content="zh" set:html={article.body_zh} />
      <div data-lang-content="pt" set:html={article.body_pt} />
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row justify-between gap-4">
      {prevArticle && (
        <a href={`/today-brazil/${prevArticle.slug}`} class="group flex items-center gap-2 text-sm text-gray-500 hover:text-brazil-green">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          <span class="line-clamp-1">{prevArticle.title_en}</span>
        </a>
      )}
      {nextArticle && (
        <a href={`/today-brazil/${nextArticle.slug}`} class="group flex items-center gap-2 text-sm text-gray-500 hover:text-brazil-green ml-auto">
          <span class="line-clamp-1">{nextArticle.title_en}</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>
  </article>
</Layout>
