---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Latest Articles — Today's Brazil"
  description="The latest daily articles on Brazilian remittance, BRL exchange rates, and financial trends."
  keywords="Brazil remittance news, BRL exchange rate, Brazil finance latest"
  image="https://images.pexels.com/photos/3943716/pexels-photo-3943716.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&fit=crop"
  type="website"
>
  <section class="bg-gradient-to-br from-brazil-blue to-blue-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-brazil-green/20 text-brazil-yellow text-sm font-semibold px-4 py-2 rounded-full mb-4">
        <span class="w-2 h-2 bg-brazil-yellow rounded-full animate-pulse"></span>
        <span data-lang-content="en">Updated Daily</span>
        <span data-lang-content="zh">每日更新</span>
        <span data-lang-content="pt">Atualizado Diariamente</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4">
        <span data-lang-content="en">Latest Articles</span>
        <span data-lang-content="zh">最新文章</span>
        <span data-lang-content="pt">Artigos Recentes</span>
      </h1>
      <p class="text-blue-200 text-lg">
        <span data-lang-content="en">Fresh insights published every day</span>
        <span data-lang-content="zh">每天发布的最新见解</span>
        <span data-lang-content="pt">Novos insights publicados todos os dias</span>
      </p>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="articles-loading" class="flex justify-center py-16">
        <div class="w-8 h-8 border-4 border-brazil-green border-t-transparent rounded-full animate-spin"></div>
      </div>
      <div id="articles-empty" class="hidden text-center text-gray-400 py-16">
        <p data-lang-content="en">No articles yet. Check back soon.</p>
        <p data-lang-content="zh">暂无文章，请稍后再来。</p>
        <p data-lang-content="pt">Nenhum artigo ainda. Volte em breve.</p>
      </div>
      <div id="articles-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>

      <div class="mt-10 text-center">
        <a
          href="/today-brazil"
          class="inline-flex items-center gap-2 text-brazil-green font-semibold hover:underline"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span data-lang-content="en">Back to Today's Brazil</span>
          <span data-lang-content="zh">返回今日巴西</span>
          <span data-lang-content="pt">Voltar ao Brasil Hoje</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.VITE_SUPABASE_URL,
    import.meta.env.VITE_SUPABASE_ANON_KEY
  );

  function getLang(): string {
    try {
      return localStorage.getItem('lang') || 'en';
    } catch {
      return 'en';
    }
  }

  function formatDate(dateStr: string, lang: string): string {
    const date = new Date(dateStr);
    if (lang === 'zh') return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
    if (lang === 'pt') return date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' });
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function getTitle(article: any, lang: string): string {
    if (lang === 'zh') return article.title_zh || article.title_en;
    if (lang === 'pt') return article.title_pt || article.title_en;
    return article.title_en;
  }

  function getExcerpt(article: any, lang: string): string {
    if (lang === 'zh') return article.excerpt_zh || article.excerpt_en;
    if (lang === 'pt') return article.excerpt_pt || article.excerpt_en;
    return article.excerpt_en;
  }

  function getReadMore(lang: string): string {
    if (lang === 'zh') return '阅读更多';
    if (lang === 'pt') return 'Leia Mais';
    return 'Read More';
  }

  function buildCard(article: any, lang: string): string {
    const title = getTitle(article, lang);
    const excerpt = getExcerpt(article, lang);
    const date = formatDate(article.published_date, lang);
    const readMore = getReadMore(lang);

    return `
      <article class="card group flex flex-col h-full">
        ${article.image_url ? `
          <div class="overflow-hidden h-48">
            <img src="${article.image_url}" alt="${title.replace(/"/g, '&quot;')}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>` : ''}
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-3">
            ${article.tag ? `<span class="px-2 py-0.5 bg-green-100 text-brazil-green text-xs font-semibold rounded-full">${article.tag}</span>` : ''}
            <time class="text-xs text-gray-400">${date}</time>
          </div>
          <h3 class="font-display font-semibold text-brazil-blue text-lg leading-snug mb-2 group-hover:text-brazil-green transition-colors">${title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed flex-1">${excerpt}</p>
          <a href="/today-brazil/article?slug=${article.slug}" class="mt-4 inline-flex items-center gap-1 text-brazil-green font-semibold text-sm hover:gap-2 transition-all">
            ${readMore}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    `;
  }

  async function loadArticles() {
    const lang = getLang();
    const loading = document.getElementById('articles-loading')!;
    const empty = document.getElementById('articles-empty')!;
    const grid = document.getElementById('articles-grid')!;

    const { data: articles } = await supabase
      .from('articles')
      .select('*')
      .eq('section', 'today-brazil')
      .order('published_date', { ascending: false });

    loading.classList.add('hidden');

    if (!articles || articles.length === 0) {
      empty.classList.remove('hidden');
      return;
    }

    grid.innerHTML = articles.map((a: any) => buildCard(a, lang)).join('');
    grid.classList.remove('hidden');
  }

  loadArticles();

  document.addEventListener('langchange', () => {
    const grid = document.getElementById('articles-grid')!;
    if (!grid.classList.contains('hidden')) {
      loadArticles();
    }
  });
</script>
