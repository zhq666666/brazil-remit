function formatDateEn(dateStr: string): string {
  const [y, m, d] = dateStr.split('-').map(Number);
  const date = new Date(y, m - 1, d);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout
  title="Today's Brazil — Daily Remittance & Finance News"
  description="Daily news and insights on Brazilian remittance, BRL exchange rates, and financial trends. Stay informed about sending money from Brazil in 2026."
  keywords="Brazil remittance news 2026, BRL exchange rate today, today Brazil finance, Brazil money transfer news, Brazil economic news, Brazilian real news, Brazil forex"
  image="https://images.pexels.com/photos/3943716/pexels-photo-3943716.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&fit=crop"
  type="website"
>
  <section class="bg-gradient-to-br from-brazil-blue to-blue-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-brazil-green/20 text-brazil-yellow text-sm font-semibold px-4 py-2 rounded-full mb-4">
        <span class="w-2 h-2 bg-brazil-yellow rounded-full"></span>
        <span>Mar 1 – Mar 8, 2026</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4">
        <span data-lang-content="en">Today's Brazil</span>
        <span data-lang-content="zh">今日巴西</span>
        <span data-lang-content="pt">Brasil Hoje</span>
      </h1>
      <p class="text-blue-200 text-lg">
        <span data-lang-content="en">Daily insights on Brazilian remittance, exchange rates, and financial culture</span>
        <span data-lang-content="zh">关于巴西汇款、汇率和金融文化的每日见解</span>
        <span data-lang-content="pt">Informações diárias sobre remessas brasileiras, taxas de câmbio e cultura financeira</span>
      </p>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <article class="card group flex flex-col h-full" data-article={JSON.stringify({
            slug: article.slug,
            tag: article.tag,
            publishedDate: article.publishedDate,
            title_en: article.title_en,
            title_zh: article.title_zh,
            title_pt: article.title_pt,
            excerpt_en: article.excerpt_en,
            excerpt_zh: article.excerpt_zh,
            excerpt_pt: article.excerpt_pt,
            imageUrl: article.imageUrl,
          })}>
            <div class="overflow-hidden h-48">
              <img
                src={article.imageUrl}
                alt={article.title_en}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-0.5 bg-green-100 text-brazil-green text-xs font-semibold rounded-full">{article.tag}</span>
                <time class="text-xs text-gray-400">{formatDateEn(article.publishedDate)}</time>
              </div>
              <h3
                class="font-display font-semibold text-brazil-blue text-lg leading-snug mb-2 group-hover:text-brazil-green transition-colors article-title"
                data-en={article.title_en}
                data-zh={article.title_zh}
                data-pt={article.title_pt}
              >
                {article.title_en}
              </h3>
              <p
                class="text-gray-500 text-sm leading-relaxed flex-1 article-excerpt"
                data-en={article.excerpt_en}
                data-zh={article.excerpt_zh}
                data-pt={article.excerpt_pt}
              >
                {article.excerpt_en}
              </p>
              <a
                href={`/today-brazil/article?slug=${article.slug}`}
                class="mt-4 inline-flex items-center gap-1 text-brazil-green font-semibold text-sm hover:gap-2 transition-all article-readmore"
              >
                <span data-lang-content="en">Read More</span>
                <span data-lang-content="zh">阅读更多</span>
                <span data-lang-content="pt">Leia Mais</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-400 text-sm mb-2">
          <span data-lang-content="en">New articles are published daily</span>
          <span data-lang-content="zh">每日发布新文章</span>
          <span data-lang-content="pt">Novos artigos são publicados diariamente</span>
        </p>
        <a
          href="/today-brazil/latest"
          class="inline-flex items-center gap-2 px-6 py-3 bg-brazil-green text-white font-semibold rounded-full hover:bg-brazil-green/90 transition-colors"
        >
          <span data-lang-content="en">See Latest Articles</span>
          <span data-lang-content="zh">查看最新文章</span>
          <span data-lang-content="pt">Ver Artigos Recentes</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  function getLang(): string {
    try {
      return localStorage.getItem('lang') || 'en';
    } catch {
      return 'en';
    }
  }

  function applyLang(lang: string) {
    document.querySelectorAll<HTMLElement>('.article-title').forEach((el) => {
      const text = el.dataset[lang] || el.dataset['en'] || '';
      el.textContent = text;
    });
    document.querySelectorAll<HTMLElement>('.article-excerpt').forEach((el) => {
      const text = el.dataset[lang] || el.dataset['en'] || '';
      el.textContent = text;
    });
  }

  applyLang(getLang());

  document.addEventListener('langchange', () => {
    applyLang(getLang());
  });
</script>
