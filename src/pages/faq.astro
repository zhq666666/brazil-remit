---
import Layout from '../layouts/Layout.astro';
import FaqSection from '../components/FaqSection.astro';
---

<Layout
  title="FAQ — Brazil International Remittance Questions Answered"
  description="Answers to the most common questions about international remittances from Brazil: limits, timing, PIX, documentation, fees, cancellations, and 2026 regulations."
  keywords="Brazil remittance FAQ, international transfer Brazil questions, PIX international FAQ, Brazil remittance limits, IOF tax Brazil, Banco Central regulations 2026, Brazil wire transfer questions"
  image="https://images.pexels.com/photos/3943716/pexels-photo-3943716.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&fit=crop"
  type="website"
>
  <section class="bg-gradient-to-br from-brazil-blue to-blue-900 py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4">
        <span data-lang-content="en">Frequently Asked Questions</span>
        <span data-lang-content="zh">常见问题解答</span>
        <span data-lang-content="pt">Perguntas Frequentes</span>
      </h1>
      <p class="text-blue-200 text-lg max-w-2xl mx-auto">
        <span data-lang-content="en">Clear answers to common questions about sending money from Brazil internationally.</span>
        <span data-lang-content="zh">关于从巴西向国际汇款常见问题的清晰解答。</span>
        <span data-lang-content="pt">Respostas claras para perguntas comuns sobre envio de dinheiro do Brasil para o exterior.</span>
      </p>
    </div>
  </section>

  <FaqSection />
</Layout>
