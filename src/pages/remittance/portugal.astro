import Layout from '../../layouts/Layout.astro';
import RemittancePage from '../../components/RemittancePage.astro';
---

<Layout
  title="Send Money from Brazil to Portugal — BRL to EUR Transfer Guide"
  description="Guide to sending money from Brazil to Portugal. Compare BRL to EUR exchange rates and fees. Essential information for the large Brazilian community living and working in Portugal."
  keywords="Brazil to Portugal remittance, BRL to EUR, send money Brazil Portugal, Brazilian community Portugal, BRL EUR rate, enviar dinheiro Brasil Portugal, brasileiros Portugal"
  image="https://images.pexels.com/photos/1534560/pexels-photo-1534560.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&fit=crop"
  type="website"
>
  <RemittancePage
    flag="🇵🇹"
    countryEn="Portugal"
    countryZh="葡萄牙"
    currencyCode="EUR"
    currencyNameEn="Euro"
    currencyNameZh="欧元"
    rate="0.16 EUR"
    heroImage="https://images.pexels.com/photos/1534560/pexels-photo-1534560.jpeg?auto=compress&cs=tinysrgb&w=1600&h=600&fit=crop"
    overviewEn="Brazil and Portugal share a deep historical, cultural, and linguistic bond that makes Portugal one of the most natural remittance destinations for Brazilians. With a shared Portuguese language and strong cultural ties dating back centuries, Portugal has become an increasingly popular destination for Brazilian migrants, students, and professionals — particularly following Portugal's recognition of citizenship rights for descendants of Portuguese nationals. Today, Brazilians form the largest foreign national group in Portugal, with over 300,000 registered residents."
    overviewZh="巴西和葡萄牙共享深厚的历史、文化和语言纽带，使葡萄牙成为巴西人最自然的汇款目的地之一。凭借共同的葡萄牙语和可追溯数百年的深厚文化联系，葡萄牙已成为巴西移民、学生和专业人士日益青睐的目的地——尤其是在葡萄牙承认葡萄牙国民后裔的公民权利之后。如今，巴西人是葡萄牙最大的外国国民群体，登记居民超过30万。"
    overviewPt="Brasil e Portugal partilham um vínculo histórico, cultural e linguístico profundo que torna Portugal um dos destinos de remessas mais naturais para os brasileiros. Com a língua portuguesa partilhada e fortes laços culturais que remontam a séculos, Portugal tornou-se um destino cada vez mais popular para migrantes, estudantes e profissionais brasileiros — especialmente após o reconhecimento por Portugal dos direitos de cidadania para descendentes de nacionais portugueses. Hoje, os brasileiros formam o maior grupo de estrangeiros em Portugal, com mais de 300.000 residentes registados."
    tip1En="EUR is widely accepted across Europe: If your recipient travels across EU countries, EUR received in Portugal can be used across the entire Eurozone without conversion."
    tip1Zh="欧元在整个欧洲广泛接受：如果您的收款人在欧盟国家间旅行，在葡萄牙收到的欧元无需兑换即可在整个欧元区使用。"
    tip1Pt="O euro é amplamente aceite em toda a Europa: Se o destinatário viajar pelos países da UE, o euro recebido em Portugal pode ser utilizado em toda a zona euro sem conversão — uma vantagem prática para a comunidade brasileira em Portugal."
    tip2En="Shared language simplifies the process: As both countries speak Portuguese, navigating remittance services is more intuitive for Brazilians transferring to Portugal compared to non-Portuguese destinations."
    tip2Zh="共同语言简化了操作流程：由于两国都说葡萄牙语，与非葡语目的地相比，巴西人向葡萄牙汇款时使用汇款服务更为直观便捷。"
    tip2Pt="A língua partilhada simplifica o processo: Como ambos os países falam português, navegar nos serviços de remessas é mais intuitivo para os brasileiros que transferem para Portugal em comparação com destinos não lusófonos."
    tip3En="SEPA transfers within the EU: Once funds are in Portugal, recipients can use SEPA transfers to move money anywhere in the Eurozone at low cost, making Portugal a useful hub for European transfers."
    tip3Zh="欧盟内的SEPA转账：一旦资金到达葡萄牙，收款人可以使用SEPA转账以低成本将资金转至欧元区任何地方，使葡萄牙成为欧洲转账的有用枢纽。"
    tip3Pt="Transferências SEPA dentro da UE: Uma vez que os fundos chegam a Portugal, os destinatários podem utilizar transferências SEPA para mover dinheiro para qualquer lugar da zona euro a baixo custo, tornando Portugal um hub útil para transferências europeias."
    communityEn="The Brazilian community in Portugal has grown dramatically over the past decade, driven by economic opportunity, shared language, and favorable immigration policies including the citizenship program for descendants of Portuguese nationals. Brazilians in Portugal are employed across sectors from technology and finance to construction and domestic services. Cultural exchange is intense — Brazilian music, food, and cultural influences are deeply embedded in modern Portuguese society."
    communityZh="过去十年，在葡萄牙的巴西社区急剧增长，这得益于经济机会、共同语言以及有利的移民政策，包括针对葡萄牙国民后裔的公民身份计划。在葡萄牙的巴西人受雇于从科技、金融到建筑和家政服务的各个行业。文化交流十分密切——巴西音乐、美食和文化影响已深深嵌入现代葡萄牙社会。"
    communityPt="A comunidade brasileira em Portugal cresceu dramaticamente na última década, impulsionada pela oportunidade económica, pela língua partilhada e pelas políticas de imigração favoráveis, incluindo o programa de cidadania para descendentes de nacionais portugueses. Os brasileiros em Portugal estão empregados em setores que vão da tecnologia e finanças à construção e serviços domésticos. O intercâmbio cultural é intenso — a música, a comida e as influências culturais brasileiras estão profundamente enraizadas na sociedade portuguesa moderna."
    regulatoryEn="Portugal is part of the European Union and uses the Euro. Money transfers to Portugal from Brazil must comply with Banco Central do Brasil regulations and EU anti-money laundering directives. As an EU member, Portugal follows stringent financial regulations including customer due diligence requirements. Transfers from Brazil above €10,000 equivalent require source of funds documentation."
    regulatoryZh="葡萄牙是欧盟成员国，使用欧元。从巴西向葡萄牙汇款必须符合巴西中央银行法规和欧盟反洗钱指令。作为欧盟成员国，葡萄牙遵循严格的金融法规，包括客户尽职调查要求。从巴西转账超过10,000欧元等值的需要提供资金来源文件。"
    regulatoryPt="Portugal faz parte da União Europeia e utiliza o euro. As transferências de dinheiro para Portugal do Brasil devem estar em conformidade com as regulamentações do Banco Central do Brasil e com as diretivas europeias de combate ao branqueamento de capitais. Como membro da UE, Portugal segue regulamentações financeiras rigorosas, incluindo requisitos de diligência devida do cliente. Transferências do Brasil acima do equivalente a €10.000 requerem documentação da origem dos fundos."
    transferTime="1–3 days"
    minAmount="R$50"
    maxAmount="R$100,000"
  />
</Layout>
