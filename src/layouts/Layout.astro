---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: string;
  publishedDate?: string;
}

const {
  title,
  description = 'Your complete guide to international remittance from Brazil — exchange rates, fees, destinations, and expert tips.',
  keywords = 'Brazil remittance, send money from Brazil, BRL exchange rate, international money transfer Brazil',
  image = 'https://images.pexels.com/photos/2549018/pexels-photo-2549018.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630&fit=crop',
  type = 'website',
  publishedDate,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const fullTitle = `${title} | BrazilRemit`;
---
<!DOCTYPE html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="BrazilRemit" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="BrazilRemit" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_CN" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": type === 'article' ? 'Article' : 'WebPage',
      "name": fullTitle,
      "description": description,
      "url": canonicalUrl,
      "inLanguage": ["en", "zh"],
      "publisher": {
        "@type": "Organization",
        "name": "BrazilRemit",
        "url": "https://brazilremit.com"
      }
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function() {
        try {
          var lang = localStorage.getItem('lang') || 'en';
          document.documentElement.setAttribute('data-lang', lang);
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
