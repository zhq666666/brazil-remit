---
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0" style="background: linear-gradient(135deg, #009C3B 50%, #FFDF00 50%);">
          <div class="w-full h-full flex items-center justify-center">
            <span class="text-white font-bold text-xs leading-none">BR</span>
          </div>
        </div>
        <span class="font-display font-bold text-brazil-blue text-lg" data-lang-content="en">BrazilRemit</span>
        <span class="font-display font-bold text-brazil-blue text-lg" data-lang-content="zh">巴西汇款</span>
        <span class="font-display font-bold text-brazil-blue text-lg" data-lang-content="pt">BrazilRemit</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <a href="/" class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green rounded-md transition-colors">
          <span data-lang-content="en">Home</span>
          <span data-lang-content="zh">首页</span>
          <span data-lang-content="pt">Início</span>
        </a>

        <!-- Remittance Dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green rounded-md transition-colors flex items-center gap-1">
            <span data-lang-content="en">Send Money</span>
            <span data-lang-content="zh">汇款</span>
            <span data-lang-content="pt">Enviar Dinheiro</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="py-2">
              <a href="/remittance/usa" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇺🇸</span>
                <span data-lang-content="en">Brazil → USA</span>
                <span data-lang-content="zh">巴西 → 美国</span>
                <span data-lang-content="pt">Brasil → EUA</span>
              </a>
              <a href="/remittance/china" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇨🇳</span>
                <span data-lang-content="en">Brazil → China</span>
                <span data-lang-content="zh">巴西 → 中国</span>
                <span data-lang-content="pt">Brasil → China</span>
              </a>
              <a href="/remittance/hong-kong" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇭🇰</span>
                <span data-lang-content="en">Brazil → Hong Kong</span>
                <span data-lang-content="zh">巴西 → 香港</span>
                <span data-lang-content="pt">Brasil → Hong Kong</span>
              </a>
              <a href="/remittance/uk" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇬🇧</span>
                <span data-lang-content="en">Brazil → UK</span>
                <span data-lang-content="zh">巴西 → 英国</span>
                <span data-lang-content="pt">Brasil → Reino Unido</span>
              </a>
              <a href="/remittance/singapore" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇸🇬</span>
                <span data-lang-content="en">Brazil → Singapore</span>
                <span data-lang-content="zh">巴西 → 新加坡</span>
                <span data-lang-content="pt">Brasil → Singapura</span>
              </a>
              <a href="/remittance/japan" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇯🇵</span>
                <span data-lang-content="en">Brazil → Japan</span>
                <span data-lang-content="zh">巴西 → 日本</span>
                <span data-lang-content="pt">Brasil → Japão</span>
              </a>
              <a href="/remittance/portugal" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
                <span>🇵🇹</span>
                <span data-lang-content="en">Brazil → Portugal</span>
                <span data-lang-content="zh">巴西 → 葡萄牙</span>
                <span data-lang-content="pt">Brasil → Portugal</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Today's Brazil Dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green rounded-md transition-colors flex items-center gap-1">
            <span data-lang-content="en">Today's Brazil</span>
            <span data-lang-content="zh">今日巴西</span>
            <span data-lang-content="pt">Brasil Hoje</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-52 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="py-2">
              <a href="/today-brazil" class="block px-4 py-2 text-sm font-medium text-brazil-green hover:bg-green-50">
                <span data-lang-content="en">All Posts</span>
                <span data-lang-content="zh">全部文章</span>
                <span data-lang-content="pt">Todos os Posts</span>
              </a>
              <div class="border-t border-gray-100 my-1"></div>
              <a href="/today-brazil/brazil-diaspora-and-remittance-lifeline" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 25, 2026</a>
              <a href="/today-brazil/pix-goes-international" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 24, 2026</a>
              <a href="/today-brazil/carnival-culture-and-currency" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 23, 2026</a>
              <a href="/today-brazil/brl-exchange-rate-analysis" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 22, 2026</a>
              <a href="/today-brazil/top-5-ways-to-send-money-from-brazil" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 21, 2026</a>
              <a href="/today-brazil/brazil-remittance-market-trends" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">Feb 20, 2026</a>
            </div>
          </div>
        </div>

        <a href="/about" class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green rounded-md transition-colors">
          <span data-lang-content="en">About Us</span>
          <span data-lang-content="zh">关于我们</span>
          <span data-lang-content="pt">Sobre Nós</span>
        </a>
      </nav>

      <!-- Right side: Lang switcher + mobile menu -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher dropdown -->
        <div class="relative" id="lang-dropdown-wrapper">
          <button
            id="lang-toggle"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 text-sm font-medium text-gray-600 hover:border-brazil-green hover:text-brazil-green transition-colors min-w-[72px] justify-center"
            aria-label="Switch language"
          >
            <span id="lang-flag">🇺🇸</span>
            <span id="lang-label">EN</span>
            <svg class="w-3 h-3 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="lang-menu" class="absolute right-0 top-full mt-1 w-36 bg-white rounded-xl shadow-lg border border-gray-100 py-1 hidden z-50">
            <button data-lang-option="en" class="lang-option w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
              <span>🇺🇸</span> English
            </button>
            <button data-lang-option="zh" class="lang-option w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
              <span>🇨🇳</span> 中文
            </button>
            <button data-lang-option="pt" class="lang-option w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-brazil-green">
              <span>🇧🇷</span> Português
            </button>
          </div>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-600 hover:text-brazil-green">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green">
        <span data-lang-content="en">Home</span>
        <span data-lang-content="zh">首页</span>
        <span data-lang-content="pt">Início</span>
      </a>
      <div class="pt-1 pb-1">
        <p class="px-3 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
          <span data-lang-content="en">Remittance</span>
          <span data-lang-content="zh">汇款</span>
          <span data-lang-content="pt">Remessas</span>
        </p>
        <a href="/remittance/usa" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇺🇸 Brasil → EUA / Brazil → USA</a>
        <a href="/remittance/china" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇨🇳 Brasil → China</a>
        <a href="/remittance/hong-kong" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇭🇰 Brasil → Hong Kong</a>
        <a href="/remittance/uk" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇬🇧 Brasil → Reino Unido</a>
        <a href="/remittance/singapore" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇸🇬 Brasil → Singapura</a>
        <a href="/remittance/japan" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇯🇵 Brasil → Japão</a>
        <a href="/remittance/portugal" class="block px-3 py-2 text-sm text-gray-700 hover:text-brazil-green">🇵🇹 Brasil → Portugal</a>
      </div>
      <a href="/today-brazil" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green">
        <span data-lang-content="en">Today's Brazil</span>
        <span data-lang-content="zh">今日巴西</span>
        <span data-lang-content="pt">Brasil Hoje</span>
      </a>
      <a href="/about" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brazil-green">
        <span data-lang-content="en">About Us</span>
        <span data-lang-content="zh">关于我们</span>
        <span data-lang-content="pt">Sobre Nós</span>
      </a>
    </div>
  </div>
</header>

<script>
  const langToggle = document.getElementById('lang-toggle');
  const langFlag = document.getElementById('lang-flag');
  const langLabel = document.getElementById('lang-label');
  const langMenu = document.getElementById('lang-menu');
  const langWrapper = document.getElementById('lang-dropdown-wrapper');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  const langDisplay: Record<string, { flag: string; label: string }> = {
    en: { flag: '🇺🇸', label: 'EN' },
    zh: { flag: '🇨🇳', label: 'ZH' },
    pt: { flag: '🇧🇷', label: 'PT' },
  };

  function applyLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    localStorage.setItem('lang', lang);
    const display = langDisplay[lang] || langDisplay['en'];
    if (langFlag) langFlag.textContent = display.flag;
    if (langLabel) langLabel.textContent = display.label;
    langMenu?.classList.add('hidden');
    document.querySelectorAll('.lang-option').forEach((btn) => {
      const el = btn as HTMLElement;
      if (el.dataset.langOption === lang) {
        el.classList.add('text-brazil-green', 'font-semibold', 'bg-green-50');
      } else {
        el.classList.remove('text-brazil-green', 'font-semibold', 'bg-green-50');
      }
    });
  }

  const savedLang = localStorage.getItem('lang') || 'en';
  applyLang(savedLang);

  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    langMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.lang-option').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const lang = target.dataset.langOption || 'en';
      applyLang(lang);
    });
  });

  document.addEventListener('click', (e) => {
    if (!langWrapper?.contains(e.target as Node)) {
      langMenu?.classList.add('hidden');
    }
  });

  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
